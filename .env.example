# .env.example
# -----------------------------------------------------------------------------
# Copy this file to ".env" and fill in your real values.
# NEVER commit your actual ".env" file with real keys to version control.
# -----------------------------------------------------------------------------

# Port the Express server will run on
PORT=5000

# Environment mode: development | production | test
NODE_ENV=development

# (Optional but recommended) GitHub Personal Access Token.
# Without this, GitHub API requests are limited to 60/hour.
# With it, the limit increases to 5000/hour.
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Google Gemini API key, used by src/services/aiService.js
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Future AI providers (uncomment and fill in when you swap providers in
# src/services/aiService.js)
# -----------------------------------------------------------------------------
# GROQ_API_KEY=
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# NVIDIA_NIM_API_KEY=

# -----------------------------------------------------------------------------
# Future database connection (when MongoDB caching is added)
# -----------------------------------------------------------------------------
# MONGODB_URI=
